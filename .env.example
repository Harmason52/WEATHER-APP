# WeatherVerse environment variables
# All keys are optional — the app gracefully falls back to high-fidelity demo data.

# OpenWeather (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Mapbox (used for the Travel Weather Explorer globe overlay)
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAI (powers Dynamic Story, Mood recommendations, Smart Assistant, Future Planner)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
